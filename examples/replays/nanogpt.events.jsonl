{"schema_version": 1, "event_id": "evt_0042", "timestamp": "2026-06-27T20:00:42Z", "type": "file_diff_created", "mission_id": "modded_nanogpt_run", "payload": {"file_path": "train_gpt.py", "diff": "--- a/train_gpt.py\n+++ b/train_gpt.py\n@@ -150,9 +150,11 @@ class CausalSelfAttention(nn.Module):\n     def forward(self, x):\n         B, T, C = x.size()\n         q, k, v = self.c_attn(x).split(self.n_embd, dim=2)\n         q = q.view(B, T, self.n_head, C // self.n_head)\n         k = k.view(B, T, self.n_head, C // self.n_head)\n+        # QK-norm: RMS-normalize queries/keys before RoPE for stabler attention logits.\n+        q = F.rms_norm(q, (q.size(-1),))\n+        k = F.rms_norm(k, (k.size(-1),))\n         q, k = apply_rotary(q), apply_rotary(k)\n"}, "experiment_id": "exp_004", "branch_id": "branch_main"}
